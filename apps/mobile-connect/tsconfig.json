{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "baseUrl": ".",
    "lib": ["ESNext", "DOM"],
    "paths": {
      "@/*": ["src/*"],
      "@ledgerhq/lumen-ui-rnative": ["src/types/lumen-ui-rnative"]
    },
    "skipLibCheck": true,
    "types": ["jest"]
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["**/node_modules", "**/Pods"]
}
